# Bicofino — dependências de sistema
# Instala tudo com: brew bundle

tap "homebrew/bundle"

# Runtime
brew "fnm"          # Node version manager (gerencia versões do Node)
brew "git"          # Git mais recente (macOS vem com versão antiga)
brew "gh"           # GitHub CLI (PRs, auth, clone)

# Deploy & infra
brew "vercel-cli"   # Vercel CLI
brew "infisical"    # Secrets manager — sincroniza .env entre máquinas

# Mídia (vídeos hero e assets)
brew "ffmpeg"       # Converter/comprimir .webm, .mp4
brew "imagemagick"  # Otimizar imagens

# Dev utilities
brew "mkcert"       # HTTPS local
brew "jq"           # Manipular JSON no terminal
