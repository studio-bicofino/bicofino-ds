# ============================================================
# Casa Nostra — secrets
# ============================================================
#
# PRIMÁRIO: Infisical (recomendado).
#   - Veja apps/casa-nostra/SETUP-INFISICAL.md
#   - `npm run dev` já roda dentro de `infisical run --env=dev --`
#
# FALLBACK: este arquivo (.env.local).
#   - Use APENAS se Infisical estiver indisponível.
#   - Rode com `npm run dev:no-infisical`.
#   - NUNCA commitar .env.local (já está no .gitignore).
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service role: APENAS server-side, jamais expor.
# Necessária para rodar migrations e operações administrativas.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Allowlist: emails autorizados a receber magic link (separados por vírgula)
CASA_NOSTRA_ALLOWLIST=woney@bicofino.com,branca@bicofino.com

# Site URL para redirect do magic link
NEXT_PUBLIC_SITE_URL=http://localhost:3040
